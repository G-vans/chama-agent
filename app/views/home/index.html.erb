<div class="max-w-6xl mx-auto pb-24">

  <!-- Nav -->
  <nav class="flex items-center justify-between py-6">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-neutral-900 text-white flex items-center justify-center font-semibold text-sm">CA</div>
      <div>
        <div class="font-semibold text-neutral-900 leading-tight">Chama Agent</div>
        <div class="text-xs text-neutral-500 leading-tight">Community operations, made accountable</div>
      </div>
    </div>
    <div class="text-xs font-medium text-neutral-600 border border-neutral-200 px-3 py-1.5 rounded-full">
      OpenAI Build Week 2026
    </div>
  </nav>

  <!-- Hero -->
  <section class="grid md:grid-cols-2 gap-10 md:gap-12 items-center py-16 md:py-24">
    <div>
      <div class="text-xs font-semibold uppercase tracking-widest text-neutral-500 mb-5">
        Built for the groups that hold families together
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-neutral-900 leading-[1.05] tracking-tight mb-6">
        Your mum's chama already runs on trust.
        <span class="text-neutral-500">We help it run with clarity.</span>
      </h1>
      <p class="text-lg text-neutral-600 leading-relaxed mb-8 max-w-xl">
        A chama is a member-run savings and investment group. Friends, relatives, neighbours, and colleagues contribute regularly, then use the shared fund for school fees, emergencies, small businesses, land, funerals, and weddings.
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Enter the live demo →",
                    chamas_path,
                    class: "bg-neutral-900 text-white px-5 py-3 rounded-lg font-medium hover:bg-neutral-800 transition text-sm" %>
        <a href="#how-it-works" class="text-neutral-700 px-5 py-3 rounded-lg font-medium hover:bg-neutral-100 transition text-sm border border-neutral-200">
          See how it works
        </a>
      </div>
    </div>

    <!-- Demo card -->
    <div class="relative">
      <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between border-b border-neutral-100 pb-4 mb-5">
          <div>
            <div class="text-xs uppercase tracking-wide text-neutral-400 mb-0.5">Mum's chama</div>
            <div class="text-lg font-semibold text-neutral-900">Umoja Women's Group</div>
          </div>
          <span class="text-xs font-medium text-neutral-600 bg-neutral-50 border border-neutral-100 px-2.5 py-1 rounded-full">12 members</span>
        </div>

        <div class="space-y-3">
          <div class="bg-neutral-50 border border-neutral-100 rounded-lg p-3.5">
            <div class="text-xs font-medium text-neutral-500">Akinyi · 7:42 PM</div>
            <p class="text-neutral-800 mt-1 text-sm">I'll send my KES 5,000 tomorrow morning.</p>
          </div>
          <div class="bg-neutral-50 border border-neutral-100 rounded-lg p-3.5 ml-6">
            <div class="text-xs font-medium text-neutral-500">Chairperson · 7:54 PM</div>
            <p class="text-neutral-800 mt-1 text-sm">Saturday: school-fees payout and late-payment policy.</p>
          </div>
          <div class="border border-neutral-200 rounded-lg p-4 mt-4">
            <div class="flex justify-between items-center">
              <span class="text-xs text-neutral-500">This month's pool</span>
              <strong class="text-neutral-900 text-lg font-semibold">KES 60,000</strong>
            </div>
            <div class="w-full h-1.5 bg-neutral-100 rounded-full mt-3 overflow-hidden">
              <div class="h-full bg-neutral-900 rounded-full" style="width: 83%"></div>
            </div>
            <div class="text-xs text-neutral-500 mt-2">10 of 12 members have contributed</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-24">
    <div class="border border-neutral-200 rounded-xl p-6 bg-white">
      <div class="text-3xl font-semibold text-neutral-900 tracking-tight">~12M</div>
      <div class="text-sm text-neutral-600 mt-2 leading-snug">Kenyans estimated to participate in chamas</div>
    </div>
    <div class="border border-neutral-200 rounded-xl p-6 bg-neutral-900 text-white">
      <div class="text-3xl font-semibold tracking-tight">~700M</div>
      <div class="text-sm text-neutral-300 mt-2 leading-snug">people estimated to use similar savings groups globally</div>
    </div>
    <div class="border border-neutral-200 rounded-xl p-6 bg-white">
      <div class="text-3xl font-semibold text-neutral-900 tracking-tight">1 promise</div>
      <div class="text-sm text-neutral-600 mt-2 leading-snug">can affect a school term, an emergency, or a family's next investment</div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="border border-neutral-200 rounded-2xl p-8 md:p-12 bg-white mb-24">
    <div class="max-w-2xl mb-10">
      <div class="text-xs font-semibold uppercase tracking-widest text-neutral-500 mb-3">From conversation to accountable action</div>
      <h2 class="text-3xl md:text-4xl font-semibold text-neutral-900 tracking-tight leading-tight">The treasurer should not have to carry the whole group in her head.</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      <% [
        ["01", "Understand", "GPT-5.6 reads contribution records and exported group conversations."],
        ["02", "Organize", "Decisions, promises, owners, arrears, and unresolved issues become visible."],
        ["03", "Act", "Officials request contributions through M-PESA and send focused reminders."],
        ["04", "Account", "Live records and PDF statements give every member a shared source of truth."]
      ].each do |number, title, copy| %>
        <div>
          <div class="text-neutral-400 font-medium text-sm mb-2"><%= number %></div>
          <h3 class="font-semibold text-neutral-900 text-base mb-2"><%= title %></h3>
          <p class="text-sm text-neutral-600 leading-relaxed"><%= copy %></p>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Global framing -->
  <section class="text-center py-8">
    <p class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Known by different names. Built on the same trust.</p>
    <p class="text-xl md:text-2xl font-semibold text-neutral-900 tracking-tight mb-4">Chama · Susu · Esusu · Tanda · Kye · ROSCA</p>
    <p class="text-neutral-600 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">The local payment rail may change. The need to preserve decisions, coordinate contributions, and protect community trust does not.</p>
  </section>

</div>
