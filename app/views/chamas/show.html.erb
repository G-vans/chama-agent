<div class="max-w-4xl mx-auto p-6 space-y-8">

  <!-- Header -->
  <div class="border-b pb-4">
    <h1 class="text-3xl font-bold text-gray-900"><%= @chama.name %></h1>
    <p class="text-gray-600 mt-1">
      <%= @chama.frequency.capitalize %> ·
      KES <%= number_with_delimiter(@chama.contribution_amount.to_i) %> per member ·
      <%= @members.count %> members
    </p>
  </div>

  <!-- Flash -->
  <% if notice %>
    <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded">
      <%= notice %>
    </div>
  <% end %>

  <!-- Health Report Section -->
  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <div class="flex justify-between items-start mb-4">
      <h2 class="text-xl font-semibold">Chama Health Report</h2>
      <%= button_to "Generate Report",
                    chama_agent_reports_path(@chama),
                    method: :post,
                    class: "bg-black text-white px-4 py-2 rounded hover:bg-gray-800" %>
    </div>

    <% if @report_content %>
      <!-- Health Score -->
      <div class="flex items-center gap-4 mb-4">
        <div class="text-5xl font-bold <%= @report_content['health_score'] >= 70 ? 'text-green-600' : @report_content['health_score'] >= 40 ? 'text-yellow-600' : 'text-red-600' %>">
          <%= @report_content["health_score"] %>
        </div>
        <div>
          <div class="text-sm text-gray-500 uppercase tracking-wide">Health Score</div>
          <div class="text-xs text-gray-400">Generated <%= time_ago_in_words(@latest_report.generated_at) %> ago</div>
        </div>
      </div>

      <!-- Narrative -->
      <p class="text-gray-800 leading-relaxed mb-6">
        <%= @report_content["narrative"] %>
      </p>

      <!-- Suggested Actions -->
      <div class="mb-6">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-2">Suggested Actions</h3>
        <ul class="space-y-2">
          <% (@report_content["suggested_actions"] || []).each do |action| %>
            <li class="flex gap-2">
              <span class="text-gray-400">→</span>
              <span class="text-gray-800"><%= action %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Meeting Agenda -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-2">Proposed Meeting Agenda</h3>
        <ul class="space-y-2">
          <% (@report_content["meeting_agenda_items"] || []).each do |item| %>
            <li class="flex gap-2">
              <span class="text-gray-400">•</span>
              <span class="text-gray-800"><%= item %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <p class="text-gray-500 italic">No health report generated yet. Click the button above.</p>
    <% end %>
  </section>

  <!-- Members Section -->
  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <h2 class="text-xl font-semibold mb-4">Members</h2>

    <div class="divide-y">
      <% @members.each do |member| %>
        <div class="flex justify-between items-center py-3">
          <div>
            <div class="font-medium text-gray-900"><%= member.name %></div>
            <div class="text-sm text-gray-500"><%= member.phone %></div>
          </div>

          <div class="text-right">
            <% if member.status == "up_to_date" %>
              <span class="text-sm text-green-700 font-medium">✓ Up to date</span>
              <div class="text-xs text-gray-500">Paid KES <%= number_with_delimiter(member.total_paid) %></div>
            <% else %>
              <span class="text-sm text-red-700 font-medium">! KES <%= number_with_delimiter(member.arrears) %> due</span>
              <div class="text-xs text-gray-500"><%= member.months_behind %> month<%= "s" if member.months_behind > 1 %> behind</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

</div>