<%= turbo_frame_tag "chama_dashboard", class: "block w-full", style: "display: block; width: 100%;" do %>
  <section class="w-full bg-white border rounded-lg p-6 shadow-sm">
    <div class="w-full max-w-6xl mx-auto p-6 space-y-8">

      <!-- Header -->
      <div class="border-b pb-4">
        <h1 class="text-3xl font-bold text-gray-900"><%= @chama.name %></h1>
        <p class="text-gray-600 mt-1">
          <%= @chama.frequency.capitalize %> ·
          KES <%= number_with_delimiter(@chama.contribution_amount.to_i) %> per member ·
          <%= @members.count %> members
        </p>
      </div>

      <!-- Flash -->
      <div id="flash">
        <%= render "shared/flash", notice: notice, alert: alert %>
      </div>

      <!-- Health Report Section (now a partial for Turbo Stream targeting) -->
      <%= render "agent_report",
                chama: @chama,
                latest_report: @latest_report,
                report_content: @report_content %>

      <!-- Members Section -->
      <section class="bg-white border rounded-lg p-6 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Members</h2>

        <%= turbo_stream_from "chama_#{@chama.id}_members" %>

        <div class="divide-y">
          <%= render partial: "members/member_row",
                     collection: @members,
                     as: :member,
                     locals: { chama: @chama, pending: false } %>
        </div>
      </section>

    </div>
    </section>
<% end %>
