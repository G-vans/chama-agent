<%= turbo_frame_tag "chat_analysis" do %>
  <section class="bg-white border rounded-lg p-6 shadow-sm">
    <div class="mb-4">
      <h2 class="text-xl font-semibold">Group Chat Intelligence</h2>
      <p class="text-sm text-gray-500 mt-1">Paste an exported WhatsApp or community-channel conversation and turn it into accountable work.</p>
    </div>

    <%= form_with url: chama_chat_analyses_path(chama), scope: :chat_analysis, class: "space-y-3" do |form| %>
      <%= form.text_area :source_text,
                         required: true,
                         rows: 7,
                         placeholder: "Paste exported group chat here...",
                         class: "w-full border rounded p-3 text-sm" %>
      <%= form.submit "Analyze Group Chat",
                      data: { turbo_submits_with: "Analyzing with GPT-5.6..." },
                      class: "bg-black text-white px-4 py-2 rounded hover:bg-gray-800" %>
    <% end %>

    <% if chat_analysis %>
      <% content = chat_analysis.parsed_content %>
      <div class="mt-6 space-y-6">
        <div class="bg-green-50 border border-green-200 rounded p-4">
          <div class="text-xs text-green-800 uppercase font-semibold">Operations brief</div>
          <p class="text-gray-800 mt-2"><%= content["summary"] %></p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold mb-2">Topics discussed</h3>
            <ul class="space-y-2 text-sm"><% Array(content["topics"]).each do |item| %><li>• <%= item %></li><% end %></ul>
          </div>
          <div>
            <h3 class="font-semibold mb-2">Decisions made</h3>
            <ul class="space-y-2 text-sm"><% Array(content["decisions"]).each do |item| %><li>✓ <%= item %></li><% end %></ul>
          </div>
        </div>

        <div>
          <h3 class="font-semibold mb-2">Action items</h3>
          <div class="space-y-2">
            <% Array(content["action_items"]).each do |item| %>
              <div class="border rounded p-3 text-sm"><strong><%= item["owner"] %>:</strong> <%= item["task"] %> <span class="text-gray-500">— <%= item["due"] %></span></div>
            <% end %>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold mb-2">Contribution promises</h3>
            <ul class="space-y-2 text-sm">
              <% Array(content["contribution_commitments"]).each do |item| %>
                <li><strong><%= item["member"] %></strong> — KES <%= number_with_delimiter(item["amount"]) %> · <%= item["when"] %></li>
              <% end %>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold mb-2">Unresolved issues</h3>
            <ul class="space-y-2 text-sm"><% Array(content["unresolved_issues"]).each do |item| %><li>! <%= item %></li><% end %></ul>
          </div>
        </div>

        <div>
          <h3 class="font-semibold mb-2">Recommended reminders</h3>
          <ul class="space-y-2 text-sm"><% Array(content["recommended_reminders"]).each do |item| %><li>→ <%= item %></li><% end %></ul>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
